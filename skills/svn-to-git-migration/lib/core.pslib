# core.pslib
# Function library backing the SVN→git migration phase runbooks.
# Dot-sourced by scripts/run-phase.pslib (itself loaded via
# [scriptblock]::Create inside an inline `powershell -Command` invocation) —
# does NOT execute anything on its own.
# Compatible with Windows PowerShell 5.1+ and PowerShell 7+.
# ─────────────────────────────────────────────────────────────────────────────
# LOGGING
# ─────────────────────────────────────────────────────────────────────────────

function Write-Log {
    param(
        [string]$Message,
        [ValidateSet('INFO', 'WARN', 'ERROR')]
        [string]$Level = 'INFO'
    )
    $tag = '[SVN→Git]'
    switch ($Level) {
        'WARN'  { Write-Host "$tag WARNING: $Message" -ForegroundColor Yellow }
        'ERROR' { Write-Host "$tag ERROR: $Message"   -ForegroundColor Red }
        default { Write-Host "$tag $Message" }
    }
}

function Write-RevProgress {
    param(
        [int]$Rev,
        [int]$Total,
        [string]$RefName,
        [string]$Msg,
        [string]$Author
    )
    $short = $RefName -replace '^refs/(heads|tags)/', ''
    # Truncate long messages for readability
    if ($Msg.Length -gt 60) { $Msg = $Msg.Substring(0, 57) + '...' }
    Write-Host "[SVN→Git] Rev $Rev/$Total`: $short — '$Msg' ($Author)" -ForegroundColor Cyan
}

# ─────────────────────────────────────────────────────────────────────────────
# SVN HELPERS
# ─────────────────────────────────────────────────────────────────────────────

function Invoke-Svn {
    <# Run svn, return stdout lines. Throws on non-zero exit. #>
    param([string[]]$SvnArgs)
    $out = & svn @SvnArgs 2>&1
    if ($LASTEXITCODE -ne 0) {
        $err = ($out | Out-String).Trim()
        throw "svn failed [exit $LASTEXITCODE]: svn $($SvnArgs -join ' ')`n$err"
    }
    return $out
}

function Invoke-SvnXml {
    <#
    Run svn with --xml flag and return a [System.Xml.XmlDocument].
    When $SourceEncoding is set the raw stdout bytes are transcoded to UTF-8
    before XML parsing, preserving non-ASCII characters in commit messages.
    #>
    param(
        [string[]]$SvnArgs,
        [string]  $SourceEncoding = ''
    )

    if ($SourceEncoding) {
        # Capture raw bytes via ProcessStartInfo so we bypass PS's string
        # conversion which would corrupt non-UTF-8 bytes.
        $psi = [System.Diagnostics.ProcessStartInfo]::new('svn')
        # Build argument string – quote args that contain spaces
        $psi.Arguments = ($SvnArgs | ForEach-Object {
            if ($_ -match '\s') { "`"$_`"" } else { $_ }
        }) -join ' '
        $psi.RedirectStandardOutput = $true
        $psi.RedirectStandardError  = $true
        $psi.UseShellExecute        = $false
        # GetEncoding(28591) = ISO-8859-1 / Latin-1 (1:1 byte→char); avoids
        # the [Encoding]::Latin1 shorthand that PS 5.1 does not expose.
        $latin1 = [System.Text.Encoding]::GetEncoding(28591)
        # Read as Latin-1 (1:1 byte→char) to preserve raw bytes
        $psi.StandardOutputEncoding = $latin1

        $proc = [System.Diagnostics.Process]::Start($psi)
        # Collect all stdout bytes
        $chars  = $proc.StandardOutput.ReadToEnd()
        $stderr = $proc.StandardError.ReadToEnd()
        $proc.WaitForExit()

        if ($proc.ExitCode -ne 0) {
            throw "svn failed [exit $($proc.ExitCode)]: $stderr"
        }

        # Re-encode: Latin-1 chars → bytes (lossless) → UTF-8 string
        $rawBytes  = $latin1.GetBytes($chars)
        $srcEnc    = [System.Text.Encoding]::GetEncoding($SourceEncoding)
        $utf8Bytes = [System.Text.Encoding]::Convert($srcEnc, [System.Text.Encoding]::UTF8, $rawBytes)
        $xmlStr    = [System.Text.Encoding]::UTF8.GetString($utf8Bytes)

        $doc = [System.Xml.XmlDocument]::new()
        $doc.LoadXml($xmlStr)
        return $doc
    }
    else {
        $out = & svn @SvnArgs 2>&1
        if ($LASTEXITCODE -ne 0) {
            $err = ($out | Out-String).Trim()
            throw "svn failed [exit $LASTEXITCODE]: svn $($SvnArgs -join ' ')`n$err"
        }
        $doc = [System.Xml.XmlDocument]::new()
        $doc.LoadXml(($out | Out-String).Trim())
        return $doc
    }
}

# ─────────────────────────────────────────────────────────────────────────────
# GIT HELPERS
# ─────────────────────────────────────────────────────────────────────────────

function Invoke-Git {
    <# Run git -C $GitDir, return trimmed stdout. Throws on non-zero exit. #>
    param(
        [string]  $GitDir,
        [string[]]$GitArgs,
        [switch]  $AllowFailure   # return $null instead of throwing
    )
    $out = & git -C $GitDir @GitArgs 2>&1
    if ($LASTEXITCODE -ne 0) {
        if ($AllowFailure) { return $null }
        $err = ($out | Out-String).Trim()
        throw "git failed [exit $LASTEXITCODE]: git $($GitArgs -join ' ')`n$err"
    }
    return ($out -join "`n").Trim()
}

function Set-GitAuthorEnv {
    param([string]$Name, [string]$Email, [string]$Date)
    $env:GIT_AUTHOR_NAME     = $Name
    $env:GIT_AUTHOR_EMAIL    = $Email
    $env:GIT_AUTHOR_DATE     = $Date
    $env:GIT_COMMITTER_NAME  = $Name
    $env:GIT_COMMITTER_EMAIL = $Email
    $env:GIT_COMMITTER_DATE  = $Date
}

function Clear-GitAuthorEnv {
    'GIT_AUTHOR_NAME','GIT_AUTHOR_EMAIL','GIT_AUTHOR_DATE',
    'GIT_COMMITTER_NAME','GIT_COMMITTER_EMAIL','GIT_COMMITTER_DATE' |
        ForEach-Object { Remove-Item "Env:\$_" -ErrorAction SilentlyContinue }
}

# ─────────────────────────────────────────────────────────────────────────────
# DATE CONVERSION
# ─────────────────────────────────────────────────────────────────────────────

function Convert-SvnDate {
    <#
    SVN XML date:  2023-04-15T10:30:00.123456Z
    git env var:   2023-04-15T10:30:00 +0000
    #>
    param([string]$SvnDate)
    try {
        $datePart = $SvnDate.Split('.')[0]   # strip microseconds
        $dt = [datetime]::ParseExact(
            $datePart,
            'yyyy-MM-ddTHH:mm:ss',
            [System.Globalization.CultureInfo]::InvariantCulture
        )
        return $dt.ToString('yyyy-MM-ddTHH:mm:ss +0000')
    }
    catch {
        # Fallback: simple string surgery
        return ($SvnDate -replace '\.\d+Z$', ' +0000')
    }
}

# ─────────────────────────────────────────────────────────────────────────────
# AUTHOR MAP
# ─────────────────────────────────────────────────────────────────────────────

function Import-AuthorMap {
    param([string]$FilePath)

    $map = [System.Collections.Generic.Dictionary[string, hashtable]]::new(
        [System.StringComparer]::Ordinal)

    if (-not $FilePath) { return $map }
    if (-not (Test-Path $FilePath)) {
        throw "Authors file not found: $FilePath"
    }

    $pattern = '^(.+?|\(no author\))\s*=\s*(.+?)\s*<(.*)>\s*$'
    foreach ($line in (Get-Content $FilePath -Encoding UTF8)) {
        if ($line -match $pattern) {
            $map[$Matches[1].Trim()] = @{
                Name  = $Matches[2].Trim()
                Email = $Matches[3].Trim()
            }
        }
    }
    return $map
}

function Resolve-Author {
    param(
        [string]$SvnUsername,
        [System.Collections.Generic.Dictionary[string, hashtable]]$AuthorMap,
        [string]$RepoUuid
    )
    $user = if ($SvnUsername) { $SvnUsername } else { '(no author)' }

    if ($AuthorMap.ContainsKey($user)) {
        return $AuthorMap[$user]
    }

    # Accumulate for summary report
    [void]$Script:Stats.UnmappedAuthors.Add($user)

    # Default: identical to what git-svn produces
    return @{ Name = $user; Email = "$user@$RepoUuid" }
}

# ─────────────────────────────────────────────────────────────────────────────
# SHA INDEX  (per-URL sorted map of revision → commit-SHA)
# ─────────────────────────────────────────────────────────────────────────────

function Update-ShaIndex {
    param([string]$Url, [int]$Rev, [string]$Sha)
    if (-not $Script:ShaIndex.ContainsKey($Url)) {
        $Script:ShaIndex[$Url] =
            [System.Collections.Generic.SortedDictionary[int, string]]::new()
    }
    $Script:ShaIndex[$Url][$Rev] = $Sha
}

function Get-CopyfromParentSha {
    <#
    "At-or-before" lookup: find the highest revision r in sha_index[url]
    where r ≤ copyfromRev, return its commit SHA.
    #>
    param([string]$CopyfromUrl, [int]$CopyfromRev)

    if (-not $Script:ShaIndex.ContainsKey($CopyfromUrl)) { return $null }

    $inner = $Script:ShaIndex[$CopyfromUrl]
    $keys  = $inner.Keys | Where-Object { $_ -le $CopyfromRev }
    if (-not $keys) { return $null }

    $maxRev = ($keys | Measure-Object -Maximum).Maximum
    return $inner[$maxRev]
}

# ─────────────────────────────────────────────────────────────────────────────
# SVN INCREMENTAL CHECKOUT (replaces per-revision svn export)
# ─────────────────────────────────────────────────────────────────────────────

function Initialize-SvnWorkingCopy {
    <#
    Check out a fresh SVN working copy at $Rev into $WcDir.
    Deletes any existing $WcDir first so the checkout is always clean.
    $Rev accepts an integer revision number OR the string 'HEAD' (default).
    #>
    param([string]$Url, [string]$Rev = 'HEAD', [string]$WcDir)
    if (Test-Path $WcDir) { Remove-Item $WcDir -Recurse -Force }
    New-Item -ItemType Directory -Path $WcDir -Force | Out-Null
    if ($Rev -eq 'HEAD') {
        Invoke-Svn @('checkout', $Url, $WcDir)
    } else {
        Invoke-Svn @('checkout', '-r', $Rev, $Url, $WcDir)
    }
}

function Copy-WcToRepo {
    <#
    Sync SVN working copy contents to the git working tree.

    Non-filtered (common path): uses robocopy /MIR which handles additions,
    modifications, AND deletions in one fast pass. This replaces the combination
    of Clear-WorkingTree + Copy-StagingToRepo + git add -A for tree management.

    Filtered path: copies WC to a temp staging dir (excluding .svn), applies
    Remove-FilteredPaths, then uses Clear-WorkingTree + Copy-StagingToRepo.

    Always excludes .svn, .git, and .svn2git from both source and dest.
    #>
    param(
        [string]$WcDir,
        [string]$GitDir,
        [string]$IgnorePattern,
        [string]$IncludePattern
    )

    if (-not $IgnorePattern -and -not $IncludePattern) {
        # Fast path: robocopy /MIR — mirrors deletions, additions, and modifications.
        # Exit codes 0–7 mean success (0=no change, 1=files copied, etc.); ≥8 = error.
        & robocopy $WcDir $GitDir /MIR /XD '.svn' '.git' '.svn2git' `
                   /NFL /NDL /NJH /NJS /NS /NC 2>&1 | Out-Null
        if ($LASTEXITCODE -ge 8) {
            throw "robocopy mirror failed (exit $LASTEXITCODE). Source: $WcDir → Dest: $GitDir"
        }
        return
    }

    # Filtered path: copy WC → temp staging dir (excluding .svn), apply filters, mirror
    $tmpDir = $WcDir + '__filtered'
    try {
        if (Test-Path $tmpDir) { Remove-Item $tmpDir -Recurse -Force }
        & robocopy $WcDir $tmpDir /E /XD '.svn' /NFL /NDL /NJH /NJS /NS /NC 2>&1 | Out-Null
        if ($LASTEXITCODE -ge 8) {
            throw "robocopy copy-to-temp failed (exit $LASTEXITCODE)"
        }
        Remove-FilteredPaths -StagingDir $tmpDir `
                             -IgnorePattern $IgnorePattern `
                             -IncludePattern $IncludePattern
        Clear-WorkingTree -GitDir $GitDir
        Copy-StagingToRepo -StagingDir $tmpDir -GitDir $GitDir
    }
    finally {
        if (Test-Path $tmpDir) { Remove-Item $tmpDir -Recurse -Force }
    }
}

# ─────────────────────────────────────────────────────────────────────────────
# PATH FILTERING  (ref-root-relative)
# ─────────────────────────────────────────────────────────────────────────────

function Test-PathIncluded {
    param([string]$RelPath, [string]$IgnorePattern, [string]$IncludePattern)
    if ($IncludePattern -and ($RelPath -notmatch $IncludePattern)) { return $false }
    if ($IgnorePattern  -and ($RelPath  -match  $IgnorePattern))  { return $false }
    return $true
}

function Remove-FilteredPaths {
    <# Delete from $StagingDir any file/dir whose relative path fails the filter. #>
    param(
        [string]$StagingDir,
        [string]$IgnorePattern,
        [string]$IncludePattern
    )
    if (-not $IgnorePattern -and -not $IncludePattern) { return }

    $base = $StagingDir.TrimEnd('\') + '\'
    Get-ChildItem -Path $StagingDir -Recurse -Force | ForEach-Object {
        $rel = $_.FullName.Substring($base.Length) -replace '\\', '/'
        if (-not (Test-PathIncluded -RelPath $rel `
                    -IgnorePattern $IgnorePattern `
                    -IncludePattern $IncludePattern)) {
            Remove-Item $_.FullName -Force -ErrorAction SilentlyContinue
        }
    }
}

# ─────────────────────────────────────────────────────────────────────────────
# WORKING TREE HELPERS
# ─────────────────────────────────────────────────────────────────────────────

function Clear-WorkingTree {
    <# Remove everything from $GitDir except the .git folder and .svn2git state dir. #>
    param([string]$GitDir)
    Get-ChildItem -Path $GitDir -Force |
        Where-Object { $_.Name -ne '.git' -and $_.Name -ne '.svn2git' } |
        Remove-Item -Recurse -Force -ErrorAction SilentlyContinue
}

function Copy-StagingToRepo {
    <# Copy staged export contents into the git working tree. #>
    param([string]$StagingDir, [string]$GitDir)
    $items = Get-ChildItem -Path $StagingDir -Force
    if (-not $items) { return }
    foreach ($item in $items) {
        $dest = Join-Path $GitDir $item.Name
        Copy-Item -Path $item.FullName -Destination $dest -Recurse -Force
    }
}

# ─────────────────────────────────────────────────────────────────────────────
# SVN:SPECIAL (SYMLINKS) — WINDOWS ONLY
# ─────────────────────────────────────────────────────────────────────────────

function Resolve-SvnSpecialFiles {
    <#
    Windows svn export produces text files with content "link <target>" for
    symlinks instead of real symlinks. Detect them and return a list of objects
    describing what needs to be staged as mode 120000.
    Returns list of [pscustomobject]@{ FileFullPath; RelPath; Target }
    #>
    param(
        [string]$StagingDir,
        [string]$RefUrl,
        [int]   $Rev
    )

    $result = [System.Collections.Generic.List[pscustomobject]]::new()
    $base   = $StagingDir.TrimEnd('\') + '\'

    $allFiles = Get-ChildItem -Path $StagingDir -Recurse -File -Force
    foreach ($f in $allFiles) {
        # Symlink placeholder files are tiny
        if ($f.Length -gt 1024) { continue }

        try   { $content = [System.IO.File]::ReadAllText($f.FullName) }
        catch { continue }

        if (-not $content.StartsWith('link ')) { continue }

        $relPath = ($f.FullName.Substring($base.Length)) -replace '\\', '/'

        # Confirm the svn:special property is actually set on this path
        $propOut = & svn propget svn:special "$RefUrl/$relPath" -r $Rev 2>&1
        if ($LASTEXITCODE -ne 0) { continue }
        $propStr = ($propOut | Out-String).Trim()
        if (-not $propStr) { continue }

        $target = $content.Substring(5).TrimEnd("`r", "`n")  # strip "link "
        $result.Add([pscustomobject]@{
            FileFullPath = $f.FullName
            RelPath      = $relPath
            Target       = $target
        })
    }
    return $result
}

function Resolve-SvnSpecialFilesLocal {
    <#
    Detects svn:special symlinks in a local SVN working copy — no network calls.
    Reads file content ("link <target>") and queries svn:special from the local WC.
    Used by the incremental checkout approach instead of Resolve-SvnSpecialFiles.
    Returns list of [pscustomobject]@{ FileFullPath; RelPath; Target }
    #>
    param([string]$WcDir)

    $result = [System.Collections.Generic.List[pscustomobject]]::new()
    $base   = $WcDir.TrimEnd('\') + '\'

    $allFiles = Get-ChildItem -Path $WcDir -Recurse -File -Force |
        Where-Object { $_.FullName -notmatch '[\\/]\.svn[\\/]' -and
                        $_.FullName -notmatch '[\\/]\.svn$' }

    foreach ($f in $allFiles) {
        if ($f.Length -gt 1024) { continue }
        try   { $content = [System.IO.File]::ReadAllText($f.FullName) }
        catch { continue }
        if (-not $content.StartsWith('link ')) { continue }

        $relPath = ($f.FullName.Substring($base.Length)) -replace '\\', '/'

        # Read svn:special from local WC — zero network round-trips
        $propOut = & svn propget svn:special $f.FullName 2>&1
        if ($LASTEXITCODE -ne 0) { continue }
        $propStr = ($propOut | Out-String).Trim()
        if (-not $propStr) { continue }

        $target = $content.Substring(5).TrimEnd("`r", "`n")
        $result.Add([pscustomobject]@{
            FileFullPath = $f.FullName
            RelPath      = $relPath
            Target       = $target
        })
    }
    return $result
}

function Resolve-SvnSpecialFilesFast {
    <#
    svn:special (symlink) detection restricted to a known changed-file set —
    the O(changed-files) counterpart to Resolve-SvnSpecialFilesLocal. Used by
    the Invoke-ConvertRef fast path, where the changed paths for this revision
    are already known from parsing the `svn update`/`checkout` output, so a
    full recursive working-copy walk is unnecessary.
    Returns list of [pscustomobject]@{ FileFullPath; RelPath; Target }
    #>
    param([string]$WcDir, [string[]]$ChangedPaths)

    $result = [System.Collections.Generic.List[pscustomobject]]::new()
    if (-not $ChangedPaths) { return $result }

    foreach ($rel in $ChangedPaths) {
        $full = Join-Path $WcDir ($rel -replace '/', '\')
        if (-not (Test-Path -LiteralPath $full -PathType Leaf)) { continue }

        $fi = Get-Item -LiteralPath $full -Force -ErrorAction SilentlyContinue
        if (-not $fi -or $fi.Length -gt 1024) { continue }

        try   { $content = [System.IO.File]::ReadAllText($full) }
        catch { continue }
        if (-not $content.StartsWith('link ')) { continue }

        # Confirm the svn:special property is actually set (local WC — no network)
        $propOut = & svn propget svn:special $full 2>&1
        if ($LASTEXITCODE -ne 0) { continue }
        $propStr = ($propOut | Out-String).Trim()
        if (-not $propStr) { continue }

        $target = $content.Substring(5).TrimEnd("`r", "`n")
        $result.Add([pscustomobject]@{
            FileFullPath = $full
            RelPath      = $rel
            Target       = $target
        })
    }
    return $result
}

function Stage-Symlinks {
    <#
    For each detected svn:special symlink:
      1. Remove the placeholder text file from the working tree (unless
         -KeepPlaceholder — see below).
      2. Hash the target string as a git blob.
      3. Stage it with mode 120000.
    Must be called AFTER git add -A (so the index has the placeholder) and
    BEFORE git write-tree.

    -KeepPlaceholder: used by the fast path, where the "working tree" being
    indexed is the live SVN working copy itself. Deleting the placeholder
    file there would make the next `svn update` see a missing file and
    restore it (or conflict). Instead the 120000 cacheinfo entry is staged
    on top of the regular entry `git add -A` already staged — the cacheinfo
    entry wins, and the on-disk placeholder is left untouched for SVN.
    #>
    param(
        [System.Collections.Generic.List[pscustomobject]]$Symlinks,
        [string]$GitDir,
        [switch]$KeepPlaceholder
    )
    foreach ($sym in $Symlinks) {
        if (-not $KeepPlaceholder) {
            # Remove placeholder from the git working tree (use RelPath so this always
            # targets $GitDir, even when the symlink was detected from an SVN WC path)
            $gitPlaceholder = Join-Path $GitDir ($sym.RelPath -replace '/', '\')
            Remove-Item $gitPlaceholder -Force -ErrorAction SilentlyContinue
        }

        # Symlink blob content is just the target path (not "link <target>")
        $blobSha = ($sym.Target | & git -C $GitDir hash-object -w --stdin 2>&1)
        if ($LASTEXITCODE -ne 0) {
            Write-Log "  Could not hash symlink blob for $($sym.RelPath)" -Level WARN
            continue
        }
        $blobSha = ($blobSha -join '').Trim()

        $cacheInfo = "120000,$blobSha,$($sym.RelPath)"
        & git -C $GitDir update-index --add --cacheinfo $cacheInfo 2>&1 | Out-Null
        if ($LASTEXITCODE -ne 0) {
            Write-Log "  Could not stage symlink $($sym.RelPath)" -Level WARN
        }
    }
}

# ─────────────────────────────────────────────────────────────────────────────
# SVN:EXECUTABLE — WINDOWS ONLY
# ─────────────────────────────────────────────────────────────────────────────

function Apply-ExecutableBits {
    <#
    Query all svn:executable properties under $RefUrl at $Rev, then run
    git update-index --chmod=+x for each matching file.
    Called after git add -A but before git write-tree.
    #>
    param([string]$GitDir, [string]$RefUrl, [int]$Rev)

    $propOut = & svn proplist --xml --depth infinity -r $Rev $RefUrl 2>&1
    if ($LASTEXITCODE -ne 0) { return }   # not fatal

    try {
        $propXml = [System.Xml.XmlDocument]::new()
        $propXml.LoadXml(($propOut | Out-String).Trim())
    }
    catch { return }

    $targets = $propXml.SelectNodes('//target')
    if (-not $targets) { return }

    foreach ($tgt in $targets) {
        $hasExec = $tgt.SelectNodes('property[@name="svn:executable"]').Count -gt 0
        if (-not $hasExec) { continue }

        $tgtPath = $tgt.GetAttribute('path')
        # path is relative to the queried URL; "." means the URL itself
        $relPath = $tgtPath.TrimStart('.').TrimStart('/') -replace '\\', '/'
        if (-not $relPath) { continue }

        & git -C $GitDir update-index --chmod=+x -- $relPath 2>&1 | Out-Null
        if ($LASTEXITCODE -eq 0) {
            Write-Log "  svn:executable → +x $relPath"
        }
    }
}

function Apply-ExecutableBitsLocal {
    <#
    Query svn:executable from the local SVN working copy — no network calls.
    Replaces Apply-ExecutableBits for the incremental checkout approach.
    Called after git add -A but before git write-tree.
    #>
    param([string]$GitDir, [string]$WcDir)

    $propOut = & svn proplist --xml --depth infinity $WcDir 2>&1
    if ($LASTEXITCODE -ne 0) { return }

    try {
        $propXml = [System.Xml.XmlDocument]::new()
        $propXml.LoadXml(($propOut | Out-String).Trim())
    }
    catch { return }

    $wcBase  = $WcDir.TrimEnd('\') + '\'
    $targets = $propXml.SelectNodes('//target')
    if (-not $targets) { return }

    foreach ($tgt in $targets) {
        $hasExec = $tgt.SelectNodes('property[@name="svn:executable"]').Count -gt 0
        if (-not $hasExec) { continue }

        $tgtPath = $tgt.GetAttribute('path')
        # Convert absolute WC path to git-relative forward-slash path
        $relPath = if ($tgtPath.StartsWith($wcBase, [System.StringComparison]::OrdinalIgnoreCase)) {
            $tgtPath.Substring($wcBase.Length) -replace '\\', '/'
        } else {
            $tgtPath.TrimStart('.').TrimStart('/') -replace '\\', '/'
        }
        if (-not $relPath) { continue }

        & git -C $GitDir update-index --chmod=+x -- $relPath 2>&1 | Out-Null
        if ($LASTEXITCODE -eq 0) {
            Write-Log "  svn:executable → +x $relPath"
        }
    }
}

function Apply-ExecutableBitsFast {
    <#
    svn:executable detection restricted to a known changed-file set — the
    O(changed-files) counterpart to Apply-ExecutableBitsLocal. Queries
    `svn proplist --xml -v` over just the changed paths (chunked to stay
    under command-line length limits) instead of a full --depth infinity
    walk of the whole working copy.
    Called after git add -A but before git write-tree.
    #>
    param([string]$GitDir, [string]$WcDir, [string[]]$ChangedPaths)

    if (-not $ChangedPaths -or @($ChangedPaths).Count -eq 0) { return }

    $wcBase    = $WcDir.TrimEnd('\') + '\'
    $fullPaths = @($ChangedPaths | ForEach-Object { Join-Path $WcDir ($_ -replace '/', '\') } |
                    Where-Object { Test-Path -LiteralPath $_ })
    if ($fullPaths.Count -eq 0) { return }

    $chunkSize = 100
    for ($i = 0; $i -lt $fullPaths.Count; $i += $chunkSize) {
        $last  = [Math]::Min($i + $chunkSize - 1, $fullPaths.Count - 1)
        $chunk = $fullPaths[$i..$last]

        $propOut = & svn proplist --xml -v $chunk 2>&1
        if ($LASTEXITCODE -ne 0) { continue }   # not fatal — leave bits as-is for this chunk

        try {
            $propXml = [System.Xml.XmlDocument]::new()
            $propXml.LoadXml(($propOut | Out-String).Trim())
        }
        catch { continue }

        $targets = $propXml.SelectNodes('//target')
        if (-not $targets) { continue }

        foreach ($tgt in $targets) {
            $hasExec = $tgt.SelectNodes('property[@name="svn:executable"]').Count -gt 0
            if (-not $hasExec) { continue }

            $tgtPath = $tgt.GetAttribute('path')
            $relPath = if ($tgtPath.StartsWith($wcBase, [System.StringComparison]::OrdinalIgnoreCase)) {
                $tgtPath.Substring($wcBase.Length) -replace '\\', '/'
            } else {
                $tgtPath.TrimStart('.').TrimStart('/') -replace '\\', '/'
            }
            if (-not $relPath) { continue }

            & git -C $GitDir update-index --chmod=+x -- $relPath 2>&1 | Out-Null
            if ($LASTEXITCODE -eq 0) {
                Write-Log "  svn:executable → +x $relPath"
            }
        }
    }
}

# ─────────────────────────────────────────────────────────────────────────────
# COPYFROM INFO
# ─────────────────────────────────────────────────────────────────────────────

function Get-CopyfromInfo {
    <#
    For a branch or tag URL, find the first revision (copy point) and extract
    the copyfrom-path / copyfrom-rev from the verbose log entry.
    Returns $null if not a copy, or [pscustomobject]@{CopyfromUrl; CopyfromRev}.
    #>
    param(
        [string]$RefUrl,
        [string]$RepoRoot,
        [string]$SourceEncoding
    )
    try {
        $logXml = Invoke-SvnXml `
            -SvnArgs @('log', '--xml', '--stop-on-copy', '-v', '--limit', '1',
                        '-r', '1:HEAD', $RefUrl) `
            -SourceEncoding $SourceEncoding
    }
    catch { return $null }

    $entries = $logXml.SelectNodes('//logentry')
    if ($entries.Count -eq 0) { return $null }

    $firstEntry = $entries[0]
    $paths      = $firstEntry.SelectNodes('paths/path')
    foreach ($p in $paths) {
        $cfPath = $p.GetAttribute('copyfrom-path')
        $cfRev  = $p.GetAttribute('copyfrom-rev')
        if ($cfPath -and $cfRev) {
            return [pscustomobject]@{
                CopyfromUrl = $RepoRoot.TrimEnd('/') + $cfPath
                CopyfromRev = [int]$cfRev
            }
        }
    }
    return $null
}

# ─────────────────────────────────────────────────────────────────────────────
# TAG DIRTY CHECK
# ─────────────────────────────────────────────────────────────────────────────

function Test-TagDirty {
    <#
    A tag is "dirty" if it has any revisions after its copy point.
    Returns $true if dirty, $false if clean.
    #>
    param([string]$TagUrl, [int]$FirstRev, [string]$SourceEncoding)

    $startRev = $FirstRev + 1
    try {
        $logXml = Invoke-SvnXml `
            -SvnArgs @('log', '--xml', '--stop-on-copy',
                        '-r', "${startRev}:HEAD", $TagUrl) `
            -SourceEncoding $SourceEncoding
    }
    catch { return $false }

    return ($logXml.SelectNodes('//logentry').Count -gt 0)
}

# ─────────────────────────────────────────────────────────────────────────────
# REVISION RANGE PARSING
# ─────────────────────────────────────────────────────────────────────────────

function Parse-RevisionRange {
    param([string]$RevRange)
    if ($RevRange -match '^(\d+):(\d+)$') {
        return @{ Start = [int]$Matches[1]; End = [int]$Matches[2] }
    }
    elseif ($RevRange -match '^(\d+):HEAD$') {
        return @{ Start = [int]$Matches[1]; End = [int]::MaxValue }
    }
    elseif ($RevRange -match '^\d+$') {
        $n = [int]$RevRange
        return @{ Start = $n; End = $n }
    }
    else {
        # Default 1:HEAD
        return @{ Start = 1; End = [int]::MaxValue }
    }
}

# ─────────────────────────────────────────────────────────────────────────────
# PHASE 0 — PREFLIGHT
# ─────────────────────────────────────────────────────────────────────────────

function Invoke-Preflight {
    param(
        [string]$SvnUrl,
        [string]$AuthorsFilePath,
        [string]$SourceEncoding
    )

    Write-Log '=== Phase 0: Preflight ==='
    Write-Log "Target URL: $SvnUrl"

    # 0.1 Reachability
    Write-Log 'Checking SVN reachability...'
    try {
        $infoXml = Invoke-SvnXml -SvnArgs @('info', '--xml', $SvnUrl) `
                                  -SourceEncoding $SourceEncoding
    }
    catch {
        Write-Log "Cannot reach SVN URL '$SvnUrl': $_" -Level ERROR
        return $null
    }

    $repoRoot = $infoXml.SelectSingleNode('//repository/root').InnerText
    $repoUuid = $infoXml.SelectSingleNode('//repository/uuid').InnerText
    $headRev  = [int]($infoXml.SelectSingleNode('//commit').GetAttribute('revision'))
    $startUrl = $infoXml.SelectSingleNode('//entry/url').InnerText

    Write-Log "  Repository root : $repoRoot"
    Write-Log "  Repository UUID : $repoUuid"
    Write-Log "  HEAD revision   : $headRev"
    Write-Log "  Canonical URL   : $startUrl"

    # 0.2 Encoding detection (read the XML declaration line)
    $rawFirst = (& svn info --xml $SvnUrl 2>&1 | Select-Object -First 2) -join ' '
    if ($rawFirst -match 'encoding="([^"]+)"') {
        $declaredEnc = $Matches[1]
        Write-Log "  SVN declared encoding: $declaredEnc"
        if ($declaredEnc -ine 'UTF-8' -and -not $SourceEncoding) {
            Write-Log ("SVN server reports encoding '$declaredEnc'. " +
                "Re-run with -Encoding $declaredEnc to transcode commit " +
                'messages and author names before processing.') -Level ERROR
            return $null
        }
    }

    # 0.3 Layout auto-detection
    $lsOut = & svn ls "$SvnUrl/trunk" 2>&1
    if ($LASTEXITCODE -eq 0) {
        Write-Log '  Standard layout detected (trunk/branches/tags). Suggest: -StdLayout'
    }
    else {
        Write-Log '  No standard layout detected. Use -StdLayout or -Trunk/-Branches/-Tags, or single-path mode.'
    }

    # 0.4 Author enumeration
    Write-Log 'Enumerating unique SVN authors...'
    $foundAuthors = [System.Collections.Generic.HashSet[string]]::new()
    try {
        $logXml = Invoke-SvnXml -SvnArgs @('log', '-q', '--xml', $SvnUrl) `
                                  -SourceEncoding $SourceEncoding
        foreach ($entry in $logXml.SelectNodes('//logentry')) {
            $aNode = $entry.SelectSingleNode('author')
            $a     = if ($aNode) { $aNode.InnerText } else { '(no author)' }
            [void]$foundAuthors.Add($a)
        }
    }
    catch {
        Write-Log "Could not enumerate authors: $_" -Level WARN
    }

    Write-Log "  Unique authors ($($foundAuthors.Count)): $($foundAuthors -join ', ')"

    if ($AuthorsFilePath) {
        $authorMap = Import-AuthorMap -FilePath $AuthorsFilePath
        $unmapped  = $foundAuthors | Where-Object { -not $authorMap.ContainsKey($_) }
        if ($unmapped) {
            Write-Log 'Authors not in map (will use default email format):' -Level WARN
            foreach ($u in $unmapped) {
                Write-Log "    $u  →  $u = $u <$u@$repoUuid>" -Level WARN
            }
        }
        else {
            Write-Log '  All authors mapped.'
        }
    }
    else {
        Write-Log ('  No -AuthorsFile supplied. All authors will use default: ' +
            "name=<svn-user>, email=<svn-user>@$repoUuid") -Level WARN
    }

    # 0.5 Size estimation
    Write-Log "HEAD revision $headRev → estimated ≤ $headRev commits to process."
    if ($headRev -gt 5000) {
        Write-Log "Large repository ($headRev revisions). Migration may take a long time." -Level WARN
    }

    Write-Log '=== Preflight complete ==='
    return [pscustomobject]@{
        RepoRoot = $repoRoot
        RepoUuid = $repoUuid
        HeadRev  = $headRev
        StartUrl = $startUrl
        Authors  = $foundAuthors
    }
}

# ─────────────────────────────────────────────────────────────────────────────
# PHASE 3 — LAYOUT / REF RESOLUTION
# ─────────────────────────────────────────────────────────────────────────────

function Resolve-Refs {
    param(
        [string]  $SvnUrl,
        [string]  $RepoRoot,
        [switch]  $UseStdLayout,
        [string]  $TrunkPath,
        [string[]]$BranchPaths,
        [string[]]$TagPaths,
        [string]  $DefaultBranch,
        [string]  $SourceEncoding
    )

    $refs = [System.Collections.Generic.List[pscustomobject]]::new()

    # Normalise layout args
    if ($UseStdLayout) {
        $TrunkPath   = 'trunk'
        $BranchPaths = @('branches')
        $TagPaths    = @('tags')
    }

    # ── Trunk / single-path ──────────────────────────────────────────────────
    if ($TrunkPath) {
        $trunkUrl = $SvnUrl.TrimEnd('/') + '/' + $TrunkPath.TrimStart('/')
        $ls = & svn ls $trunkUrl 2>&1
        if ($LASTEXITCODE -eq 0) {
            $refs.Add([pscustomobject]@{
                RefName     = "refs/heads/$DefaultBranch"
                SvnUrl      = $trunkUrl
                IsTag       = $false
                TagName     = $null
                CopyfromUrl = $null
                CopyfromRev = $null
            })
        }
        else {
            Write-Log "Trunk path not accessible: $trunkUrl" -Level WARN
        }
    }
    elseif (-not $BranchPaths -and -not $TagPaths) {
        # Single-path mode: treat the supplied URL as the one branch
        $refs.Add([pscustomobject]@{
            RefName     = "refs/heads/$DefaultBranch"
            SvnUrl      = $SvnUrl
            IsTag       = $false
            TagName     = $null
            CopyfromUrl = $null
            CopyfromRev = $null
        })
    }

    # ── Branches ─────────────────────────────────────────────────────────────
    foreach ($bp in $BranchPaths) {
        $baseUrl = $SvnUrl.TrimEnd('/') + '/' + $bp.TrimStart('/')
        $lsOut   = & svn ls --xml $baseUrl 2>&1
        if ($LASTEXITCODE -ne 0) {
            Write-Log "Branches container not accessible: $baseUrl" -Level WARN
            continue
        }
        try {
            $lsDoc = [System.Xml.XmlDocument]::new()
            $lsDoc.LoadXml(($lsOut | Out-String).Trim())
        }
        catch {
            Write-Log "Failed to parse branch listing for $baseUrl" -Level WARN
            continue
        }

        foreach ($entry in $lsDoc.SelectNodes('//entry')) {
            $name = $entry.SelectSingleNode('name').InnerText.TrimEnd('/')
            if (-not $name) { continue }
            $branchUrl = $baseUrl.TrimEnd('/') + '/' + $name
            $cf = Get-CopyfromInfo -RefUrl $branchUrl -RepoRoot $RepoRoot `
                                   -SourceEncoding $SourceEncoding
            $refs.Add([pscustomobject]@{
                RefName     = "refs/heads/$name"
                SvnUrl      = $branchUrl
                IsTag       = $false
                TagName     = $null
                CopyfromUrl = if ($cf) { $cf.CopyfromUrl } else { $null }
                CopyfromRev = if ($cf) { $cf.CopyfromRev } else { $null }
            })
        }
    }

    # ── Tags ─────────────────────────────────────────────────────────────────
    foreach ($tp in $TagPaths) {
        $baseUrl = $SvnUrl.TrimEnd('/') + '/' + $tp.TrimStart('/')
        $lsOut   = & svn ls --xml $baseUrl 2>&1
        if ($LASTEXITCODE -ne 0) {
            Write-Log "Tags container not accessible: $baseUrl" -Level WARN
            continue
        }
        try {
            $lsDoc = [System.Xml.XmlDocument]::new()
            $lsDoc.LoadXml(($lsOut | Out-String).Trim())
        }
        catch {
            Write-Log "Failed to parse tag listing for $baseUrl" -Level WARN
            continue
        }

        foreach ($entry in $lsDoc.SelectNodes('//entry')) {
            $name = $entry.SelectSingleNode('name').InnerText.TrimEnd('/')
            if (-not $name) { continue }
            $tagUrl = $baseUrl.TrimEnd('/') + '/' + $name
            $cf = Get-CopyfromInfo -RefUrl $tagUrl -RepoRoot $RepoRoot `
                                   -SourceEncoding $SourceEncoding
            $refs.Add([pscustomobject]@{
                RefName     = "refs/tags/$name"
                SvnUrl      = $tagUrl
                IsTag       = $true
                TagName     = $name
                CopyfromUrl = if ($cf) { $cf.CopyfromUrl } else { $null }
                CopyfromRev = if ($cf) { $cf.CopyfromRev } else { $null }
            })
        }
    }

    return $refs
}

# ─────────────────────────────────────────────────────────────────────────────
# O(CHANGED-FILES) FAST PATH — operate git directly against the SVN working
# copy instead of mirroring it into the git worktree first. Only used by
# Invoke-ConvertRef when neither -IgnorePattern nor -IncludePattern is set.
# ─────────────────────────────────────────────────────────────────────────────

function Get-ChangedPathsFromSvnOutput {
    <#
    Parse the stdout lines of `svn checkout`/`svn update` into a list of
    working-copy-relative, forward-slash paths that changed in this
    revision. Returns $null (never an empty-but-valid array in the failure
    case) if any line could not be classified as either a status line or a
    known summary line — callers MUST fall back to a full-tree scan for that
    revision when this happens, since correctness beats speed.
    #>
    param([string[]]$Lines, [string]$WcDir)

    $changed = [System.Collections.Generic.List[string]]::new()
    # ,$changed (not bare $changed): PowerShell unrolls an IEnumerable return
    # value onto the pipeline, so a bare return of an EMPTY list yields ZERO
    # pipeline objects — the caller sees $null, indistinguishable from a real
    # parse failure. The unary comma wraps it as a single pipeline object so
    # an empty-but-valid result stays a countable (empty) collection.
    if (-not $Lines) { return ,$changed }

    $wcBase = $WcDir.TrimEnd('\') + '\'
    $summaryPattern = '^(Updating |Updated to revision|Checked out revision|At revision|' +
        'Fetching external|External at revision|Summary of conflicts|Skipped |' +
        'Restored |Resolved conflicted state)'

    foreach ($raw in $Lines) {
        if ($null -eq $raw) { continue }
        $line = $raw.ToString().TrimEnd("`r")
        if ($line.Trim() -eq '') { continue }
        if ($line -match $summaryPattern) { continue }

        if ($line -match '^\s{0,3}([ADUCGER])([ADUCGER ])?\s+(.+)$') {
            $p = $Matches[3].Trim()
            if ($p.StartsWith($wcBase, [System.StringComparison]::OrdinalIgnoreCase)) {
                $p = $p.Substring($wcBase.Length)
            }
            elseif ($p.StartsWith($WcDir, [System.StringComparison]::OrdinalIgnoreCase)) {
                $p = $p.Substring($WcDir.Length).TrimStart('\', '/')
            }
            $p = $p -replace '\\', '/'
            if ($p) { $changed.Add($p) }
            continue
        }

        # Unrecognized line — signal the caller to fall back to a full scan.
        return $null
    }

    # See the comment on the early return above: wrap so an empty-but-valid
    # result (e.g. input was only summary lines — nothing changed) is not
    # unrolled into $null and misrouted to the full-scan fallback.
    return ,$changed
}

function Add-SvnExclude {
    <#
    Append '.svn/' AND '.svn2git/' to <GitDir>\.git\info\exclude (idempotent,
    checked line-by-line) so neither SVN's metadata directory nor the
    migration's own state directory is ever staged. Must be called
    UNCONDITIONALLY (both fast and filtered paths) once per ref, right after
    checkout — $GitDir physically contains .svn2git\ (config.json,
    sha-index.json, logs, ...) alongside the git worktree, and a bare
    `git add -A` against $GitDir (the filtered/fallback path) would otherwise
    stage and commit it. `.git/info/exclude` applies to `git add` regardless
    of which --work-tree is in effect, so one call per ref is enough.
    #>
    param([string]$GitDir)

    $excludePath = Join-Path $GitDir '.git\info\exclude'
    $excludeDir  = Split-Path $excludePath -Parent
    if (-not (Test-Path $excludeDir)) { New-Item -ItemType Directory -Path $excludeDir -Force | Out-Null }

    $existing = @()
    if (Test-Path $excludePath) { $existing = @(Get-Content $excludePath) }
    foreach ($pattern in @('.svn/', '.svn2git/')) {
        if ($existing -notcontains $pattern) {
            Add-Content -LiteralPath $excludePath -Value $pattern
            $existing += $pattern
        }
    }
}

function Invoke-GitFastAdd {
    <#
    `git add -A` run directly against the SVN working copy via an explicit
    --git-dir/--work-tree pair, so the git index (which lives under
    <GitDir>\.git) is updated from files that physically live in $WcDir —
    no robocopy mirror step required. `-C $WcDir` pins the process's cwd to
    the work-tree root so "-A" pathspec resolution is unambiguous.
    #>
    param([string]$GitDotGit, [string]$WcDir)

    $out = & git "--git-dir=$GitDotGit" "--work-tree=$WcDir" -C $WcDir add -A 2>&1
    if ($LASTEXITCODE -ne 0) {
        $err = ($out | Out-String).Trim()
        throw "git add -A (fast path) failed: $err"
    }
}

function Invoke-GitGcAuto {
    <#
    Best-effort `git gc --auto` — swallows all output/errors since this is
    purely a housekeeping optimization, never allowed to fail the migration.
    Gated to phases 4/5 (trunk/branch conversion, where commit volume is
    highest) per spec; a no-op for any other/absent $Phase.
    #>
    param([string]$GitDir, [string]$Phase)
    if ($Phase -ne '4' -and $Phase -ne '5') { return }
    & git -C $GitDir gc --auto 2>&1 | Out-Null
}

# ─────────────────────────────────────────────────────────────────────────────
# PHASE 4–6 — PER-REF CONVERSION
# ─────────────────────────────────────────────────────────────────────────────

function Invoke-ConvertRef {
    <#
    Returns 'complete' on normal completion (including converted-nothing /
    already-fully-converted / clean-tag-fast-path exits) or 'checkpoint' if
    the time budget (-Deadline) was hit mid-ref and the caller should stop
    the ref loop and re-run this phase later to pick up where it left off.
    #>
    param(
        [pscustomobject]$Ref,
        [string]        $GitDir,
        [string]        $StagingDir,
        [string]        $RepoUuid,
        [hashtable]     $RevRange,       # @{Start;End}
        [System.Collections.Generic.Dictionary[string,hashtable]]$AuthorMap,
        [string]        $IgnorePattern,
        [string]        $IncludePattern,
        [switch]        $KeepEmpty,
        [switch]        $OmitMetadata,
        [switch]        $AllTagsAsBranches,
        [string]        $SourceEncoding,
        [string]        $StateDir = '',
        [string]        $Phase    = '',
        [Nullable[datetime]] $Deadline = $null
    )

    $refName = $Ref.RefName
    $refUrl  = $Ref.SvnUrl

    # Fast path (O(changed-files)) only applies when there is no path filtering —
    # the filtered path needs the full robocopy-staging flow to apply the filter.
    $useFastPath = (-not $IgnorePattern) -and (-not $IncludePattern)
    $gitDotGit   = Join-Path $GitDir '.git'

    Write-Log "── Processing ref: $refName ($refUrl)"

    # ── 4.1 Get revision list ─────────────────────────────────────────────
    try {
        $logXml = Invoke-SvnXml `
            -SvnArgs @('log', '--xml', '--stop-on-copy', '-v',
                        '-r', '1:HEAD', $refUrl) `
            -SourceEncoding $SourceEncoding
    }
    catch {
        Write-Log "Could not get log for $refUrl`: $_" -Level WARN
        return 'complete'
    }

    $allEntries = $logXml.SelectNodes('//logentry')
    if ($allEntries.Count -eq 0) {
        Write-Log "  No revisions found for $refUrl. Skipping." -Level WARN
        return 'complete'
    }

    # Apply --revision filter
    $entries = $allEntries | Where-Object {
        $r = [int]$_.GetAttribute('revision')
        $r -ge $RevRange.Start -and $r -le $RevRange.End
    }
    if (-not $entries -or @($entries).Count -eq 0) {
        Write-Log "  No revisions in range $($RevRange.Start):$($RevRange.End) for $refUrl. Skipping."
        return 'complete'
    }

    # Force array — Sort-Object returns a scalar for single-item input, which makes
    # $sortedEntries[0] return $null on XmlElement (no indexer). @() enforces array.
    [object[]]$sortedEntries = @(@($entries) | Sort-Object { [int]$_.GetAttribute('revision') })
    $totalRevs     = $sortedEntries.Count
    $firstRev      = [int]$sortedEntries[0].GetAttribute('revision')

    # ── Tag dirty / clean check (Phase 6) ────────────────────────────────
    # Always computed from the ORIGINAL first revision — resume trimming below
    # must not change dirty/clean classification or fast-path tag naming.
    $effectiveRefName = $refName
    $isCleanTag       = $false

    if ($Ref.IsTag -and -not $AllTagsAsBranches) {
        $dirty = Test-TagDirty -TagUrl $refUrl -FirstRev $firstRev `
                               -SourceEncoding $SourceEncoding
        if ($dirty) {
            $branchName       = 'tags/' + $Ref.TagName
            $effectiveRefName = "refs/heads/$branchName"
            Write-Log ("  WARNING: $($Ref.TagName) has commits after the copy point " +
                "— created as branch refs/heads/$branchName") -Level WARN
            [void]$Script:Stats.DirtyTags.Add($Ref.TagName)
        }
        else {
            $isCleanTag = $true
        }
    }
    elseif ($Ref.IsTag -and $AllTagsAsBranches) {
        $effectiveRefName = "refs/heads/tags/$($Ref.TagName)"
    }

    # ── Fast path: clean tag whose copyfrom commit is already in the SHA index ──
    # A clean SVN tag is just a copy of another ref at a specific revision.
    # The corresponding git commit already exists from Phase 4/5 — no checkout needed.
    # (The index lookup here is keyed by the copyfrom ref's URL, not $refUrl —
    # unrelated to the resume logic below, which is keyed by this ref's own URL.)
    if ($isCleanTag -and $Ref.CopyfromUrl -and $Ref.CopyfromRev) {
        $tagSha = Get-CopyfromParentSha -CopyfromUrl $Ref.CopyfromUrl `
                                        -CopyfromRev $Ref.CopyfromRev
        if ($tagSha) {
            Write-Log "  Clean tag fast path: $($Ref.TagName) → $($tagSha.Substring(0,8))"

            # Idempotency: skip if tag already exists (re-run safety)
            $existingTagCommit = Invoke-Git -GitDir $GitDir `
                                            -GitArgs @('rev-list', '-n', '1', "refs/tags/$($Ref.TagName)") `
                                            -AllowFailure
            if ($existingTagCommit) {
                if ($existingTagCommit -eq $tagSha) {
                    Write-Log "  Tag $($Ref.TagName) already exists at correct commit — skipping."
                } else {
                    Write-Log ("  Tag $($Ref.TagName) already exists at a different commit " +
                        "($($existingTagCommit.Substring(0,8))). Skipping to preserve existing tag.") -Level WARN
                }
                # No-op re-run path — do NOT increment TotalTags (Write-Summary now
                # derives ref counts live from git, but stats.json should still stay
                # roughly honest for anything that reads it directly).
                return 'complete'
            }

            $entry0 = $sortedEntries[0]
            $aNode  = $entry0.SelectSingleNode('author')
            $svnUser = if ($aNode) { $aNode.InnerText } else { '' }
            $svnDate = $entry0.SelectSingleNode('date').InnerText
            $authorInfo = Resolve-Author -SvnUsername $svnUser -AuthorMap $AuthorMap -RepoUuid $RepoUuid
            Set-GitAuthorEnv -Name $authorInfo.Name -Email $authorInfo.Email `
                             -Date (Convert-SvnDate -SvnDate $svnDate)
            try {
                & git -C $GitDir tag -a -m "SVN tag $($Ref.TagName)" `
                      --cleanup=verbatim $Ref.TagName $tagSha 2>&1 | Out-Null
                if ($LASTEXITCODE -ne 0) {
                    Write-Log "  git tag failed for $($Ref.TagName)" -Level WARN
                }
            }
            finally {
                Clear-GitAuthorEnv
            }
            $Script:Stats.TotalTags++
            Write-Log "  → tag $($Ref.TagName) @ $($tagSha.Substring(0,8)) (fast path, no checkout)"
            return 'complete'
        }
        Write-Log ("  Clean tag $($Ref.TagName): copyfrom SHA not in index " +
            "— falling back to full checkout") -Level WARN
    }

    # ── Resolve copyfrom parent SHA (Phase 5) ────────────────────────────
    $parentSha = $null
    if ($Ref.CopyfromUrl) {
        $parentSha = Get-CopyfromParentSha -CopyfromUrl $Ref.CopyfromUrl `
                                           -CopyfromRev $Ref.CopyfromRev
        if ($parentSha) {
            Write-Log "  Copyfrom parent: $($Ref.CopyfromUrl)@$($Ref.CopyfromRev) → $($parentSha.Substring(0,8))..."
        }
        else {
            Write-Log ("  Copyfrom ref $($Ref.CopyfromUrl)@$($Ref.CopyfromRev) not in SHA index." +
                ' Creating as root commit.') -Level WARN
            [void]$Script:Stats.OrphanedBranches.Add($effectiveRefName)
        }
    }

    # ── True resume: skip revisions this ref's SHA index already recorded ──
    # The SHA index is keyed by $refUrl regardless of $effectiveRefName, so
    # this works the same for plain branches, dirty-tag branches, and tags
    # converted via the AllTagsAsBranches path.
    $resumeRev = $null
    $resumeSha = $null
    if ($Script:ShaIndex.ContainsKey($refUrl)) {
        $idxForRef = $Script:ShaIndex[$refUrl]
        if ($idxForRef.Count -gt 0) {
            $resumeRev = ($idxForRef.Keys | Measure-Object -Maximum).Maximum
            $resumeSha = $idxForRef[$resumeRev]
        }
    }

    $remainingEntries = $sortedEntries
    if ($null -ne $resumeRev) {
        $remainingEntries = @($sortedEntries | Where-Object { [int]$_.GetAttribute('revision') -gt $resumeRev })
        if ($remainingEntries.Count -ne $sortedEntries.Count) {
            Write-Log "  Resuming $effectiveRefName after r$resumeRev — $($remainingEntries.Count) revisions remaining"
        }
    }

    $revIdx           = 0
    $lastCommitSha    = $null
    $lastAuthorInfo   = $null
    $lastGitDate      = $null
    $lastConvertedRev = if ($null -ne $resumeRev) { $resumeRev } else { 0 }
    $commitsThisRef   = 0

    if ($null -ne $resumeRev -and $remainingEntries.Count -eq 0) {
        # Every revision for this ref is already in the SHA index — the only
        # thing that could still be missing is the ref/tag update itself
        # (e.g. a crash between the last commit-tree and update-ref). Skip
        # checkout/replay entirely and fall through to ref finalization below.
        $lastCommitSha = $resumeSha
        $lastEntry     = $sortedEntries[$sortedEntries.Count - 1]
        $aNodeLast     = $lastEntry.SelectSingleNode('author')
        $svnUserLast   = if ($aNodeLast) { $aNodeLast.InnerText } else { '' }
        $svnDateLast   = $lastEntry.SelectSingleNode('date').InnerText
        $lastAuthorInfo = Resolve-Author -SvnUsername $svnUserLast -AuthorMap $AuthorMap -RepoUuid $RepoUuid
        $lastGitDate    = Convert-SvnDate -SvnDate $svnDateLast
        Write-Log "  $effectiveRefName already fully converted (through r$resumeRev) — only finalizing the ref."
    }
    else {
        if ($null -ne $resumeRev -and $resumeSha) {
            # Resuming mid-ref: parent for the next commit is the last converted
            # commit of THIS ref, not the copyfrom parent computed above.
            $parentSha     = $resumeSha
            $lastCommitSha = $resumeSha
        }

        $sortedEntries = $remainingEntries
        $totalRevs     = $sortedEntries.Count
        $checkoutRev   = [int]$sortedEntries[0].GetAttribute('revision')

        # ── 4.1.5 Initialize incremental SVN working copy (once per ref) ─────
        # svn checkout at the first (remaining) revision; subsequent revisions
        # use svn update. This replaces per-revision svn export — network cost
        # drops from O(R×F) to O(F+Δ).
        # Output is captured (not left bare) for two reasons: (1) the checkout
        # itself prints an `A    <path>` line per file, which the FIRST loop
        # iteration needs — svn:special/svn:executable on ref creation would
        # otherwise be missed — see $pendingCheckoutOutput below; and (2) a
        # bare, uncaptured call here would leak its stdout lines into this
        # function's own output stream, corrupting the 'complete'/'checkpoint'
        # return value for the caller.
        Write-Log "  Checking out $refUrl@$checkoutRev …"
        $checkoutOutput = $null
        try {
            $checkoutOutput = Initialize-SvnWorkingCopy -Url $refUrl -Rev $checkoutRev -WcDir $StagingDir
        }
        catch {
            Write-Log ("svn checkout failed for $refUrl@$checkoutRev. Aborting.`n" +
                "URL: $refUrl`nRevision: $checkoutRev`nError: $_") -Level ERROR
            throw
        }

        # Unconditional — both the fast path (git add -A run directly against
        # the SVN WC) and the filtered/fallback path (git add -A run against
        # $GitDir, which physically contains .svn2git\) need .svn/ and
        # .svn2git/ excluded from staging.
        Add-SvnExclude -GitDir $GitDir

        # Folded into the FIRST loop iteration's changed-path set, then cleared —
        # see the fast-path branch inside the loop below.
        $pendingCheckoutOutput = $checkoutOutput

        foreach ($entry in $sortedEntries) {

            # ── Time budget check (top of loop) ───────────────────────────
            if ($Deadline -and (Get-Date) -ge $Deadline) {
                if ($StateDir) { Save-MigrationState -StateDir $StateDir }
                Write-MigrationProgress -StateDir $StateDir -Phase $Phase -RefName $effectiveRefName `
                    -Rev $lastConvertedRev -RevIndex $revIdx -RevTotal $totalRevs `
                    -Commits $Script:Stats.TotalCommits -Status 'checkpoint' `
                    -Message 'Time budget reached.'
                Write-Host "CHECKPOINT: phase=$Phase ref=$effectiveRefName rev=$lastConvertedRev"
                return 'checkpoint'
            }

            $revIdx++
            $rev      = [int]$entry.GetAttribute('revision')
            $aNode    = $entry.SelectSingleNode('author')
            $svnUser  = if ($aNode) { $aNode.InnerText } else { '' }
            $svnDate  = $entry.SelectSingleNode('date').InnerText
            $msgNode  = $entry.SelectSingleNode('msg')
            $svnMsg   = if ($msgNode) { $msgNode.InnerText } else { '' }

            $authorInfo = Resolve-Author -SvnUsername $svnUser `
                                         -AuthorMap $AuthorMap `
                                         -RepoUuid $RepoUuid
            $gitDate    = Convert-SvnDate -SvnDate $svnDate

            Write-RevProgress -Rev $rev -Total $totalRevs `
                              -RefName $effectiveRefName `
                              -Msg $svnMsg -Author $svnUser

            $Script:Stats.SvnRevisions++

            try {
                # ── 4.2 Update SVN working copy to $rev (incremental delta) ──
                # First (remaining) revision: WC is already at $checkoutRev.
                # Subsequent revisions: svn update applies only the delta.
                try {
                    $updateOutput = Invoke-Svn @('update', '-r', $rev, $StagingDir)
                }
                catch {
                    Write-Log ("svn update failed for $refUrl@$rev. Aborting.`n" +
                        "URL: $refUrl`nRevision: $rev`nError: $_") -Level ERROR
                    throw
                }

                $changedPaths = $null
                if ($useFastPath) {
                    $changedPaths = Get-ChangedPathsFromSvnOutput -Lines $updateOutput -WcDir $StagingDir

                    # First loop iteration only: the initial checkout delivered the
                    # whole tree (or whole remaining subtree on resume) via its own
                    # `A    <path>` lines, which this iteration's `svn update`
                    # (a same-revision no-op) does NOT repeat. Union the two parses
                    # so symlinks/executable bits present at checkout are not missed.
                    if ($null -ne $pendingCheckoutOutput) {
                        $checkoutChangedPaths = Get-ChangedPathsFromSvnOutput -Lines $pendingCheckoutOutput -WcDir $StagingDir
                        if ($null -eq $checkoutChangedPaths -or $null -eq $changedPaths) {
                            # Either parse failed to classify a line — correctness over
                            # speed: fall back to a full scan for this first revision only.
                            $changedPaths = $null
                        }
                        else {
                            $changedPaths = @((@($checkoutChangedPaths) + @($changedPaths)) | Select-Object -Unique)
                        }
                        $pendingCheckoutOutput = $null
                    }
                }

                if ($useFastPath -and $null -ne $changedPaths) {
                    # ── 4.3 (fast path) Index the SVN WC directly — no mirror copy ──
                    Invoke-GitFastAdd -GitDotGit $gitDotGit -WcDir $StagingDir

                    # ── 4.4 (fast path) svn:special over the changed set only ──
                    [object[]]$symlinks = @(Resolve-SvnSpecialFilesFast -WcDir $StagingDir -ChangedPaths $changedPaths)
                    if ($symlinks.Count -gt 0) {
                        Stage-Symlinks -Symlinks $symlinks -GitDir $GitDir -KeepPlaceholder
                    }

                    # ── svn:executable over the changed set only ──
                    Apply-ExecutableBitsFast -GitDir $GitDir -WcDir $StagingDir -ChangedPaths $changedPaths
                }
                else {
                    # Filtered path, or fast-path parse failure for this revision
                    # (correctness over speed): full mirror + full scans.
                    # ── 4.3 Mirror WC → git working tree (robocopy handles deletes too) ──
                    Copy-WcToRepo -WcDir $StagingDir -GitDir $GitDir `
                                  -IgnorePattern $IgnorePattern `
                                  -IncludePattern $IncludePattern

                    # ── 4.4 Detect svn:special from local WC (no network) ──
                    [object[]]$symlinks = @(Resolve-SvnSpecialFilesLocal -WcDir $StagingDir)

                    Invoke-Git -GitDir $GitDir -GitArgs @('add', '-A') | Out-Null

                    if ($symlinks.Count -gt 0) {
                        Stage-Symlinks -Symlinks $symlinks -GitDir $GitDir
                    }

                    Apply-ExecutableBitsLocal -GitDir $GitDir -WcDir $StagingDir
                }

                # ── 4.6 Write tree + empty commit detection ───────────────
                $newTreeSha = Invoke-Git -GitDir $GitDir -GitArgs @('write-tree')

                # Compare against the PARENT commit's tree, not HEAD — HEAD is
                # unborn during Phase 4, so a HEAD^{tree} comparison never fires.
                $baseTreeSha = if ($parentSha) {
                    Invoke-Git -GitDir $GitDir -GitArgs @('rev-parse', "$parentSha^{tree}") -AllowFailure
                } else {
                    '4b825dc642cb6eb9a060e54bf8d69288fbee4904'   # empty-tree SHA
                }

                $isEmptyCommit = ($newTreeSha -eq $baseTreeSha)
                if ($isEmptyCommit -and -not $KeepEmpty) {
                    Write-Log "  Rev ${rev}: empty tree (same as parent). Skipping."
                    $Script:Stats.SkippedEmpty++
                    # Still index this rev pointing at whatever parentSha is
                    if ($lastCommitSha) {
                        Update-ShaIndex -Url $refUrl -Rev $rev -Sha $lastCommitSha
                    }
                    continue
                }

                # ── 4.7 Author + date env vars ────────────────────────────
                Set-GitAuthorEnv -Name $authorInfo.Name -Email $authorInfo.Email `
                                 -Date $gitDate

                # ── 4.8 Commit message (+ optional git-svn-id trailer) ────
                $commitMsg = $svnMsg
                if (-not $OmitMetadata) {
                    $commitMsg = $svnMsg.TrimEnd() + "`n`ngit-svn-id: $refUrl@$rev $RepoUuid"
                }

                # ── 4.9 Create commit object ──────────────────────────────
                try {
                    $oldEAP = $ErrorActionPreference
                    $ErrorActionPreference = 'Continue'   # prevent PS from treating git stderr as terminating
                    if ($parentSha) {
                        $commitSha = $commitMsg | & git -C $GitDir commit-tree $newTreeSha -p $parentSha 2>&1
                    }
                    else {
                        $commitSha = $commitMsg | & git -C $GitDir commit-tree $newTreeSha 2>&1
                    }
                    $ErrorActionPreference = $oldEAP

                    if ($LASTEXITCODE -ne 0) {
                        $err = ($commitSha | Out-String).Trim()
                        throw "git commit-tree failed: $err"
                    }
                    $commitSha = ($commitSha -join '').Trim()
                }
                finally {
                    Clear-GitAuthorEnv
                }

                # ── 4.10 Update SHA index ─────────────────────────────────
                Update-ShaIndex -Url $refUrl -Rev $rev -Sha $commitSha

                $parentSha      = $commitSha
                $lastCommitSha  = $commitSha
                $lastAuthorInfo = $authorInfo
                $lastGitDate    = $gitDate

                $Script:Stats.TotalCommits++
                $commitsThisRef++
            }
            finally {
                $lastConvertedRev = $rev

                Write-MigrationProgress -StateDir $StateDir -Phase $Phase -RefName $effectiveRefName `
                    -Rev $rev -RevIndex $revIdx -RevTotal $totalRevs `
                    -Commits $Script:Stats.TotalCommits -Status 'running'

                if ($StateDir -and ($revIdx % 50 -eq 0)) { Save-MigrationState -StateDir $StateDir }

                if ($commitsThisRef -gt 0 -and ($commitsThisRef % 1000 -eq 0)) {
                    Invoke-GitGcAuto -GitDir $GitDir -Phase $Phase
                }
            }
        }
    }

    if (-not $lastCommitSha) {
        Write-Log "  No commits produced for $effectiveRefName. Ref not created." -Level WARN
        # Clean up the SVN working copy
        if (Test-Path $StagingDir) { Remove-Item $StagingDir -Recurse -Force -ErrorAction SilentlyContinue }
        return 'complete'
    }

    # ── Update git ref ────────────────────────────────────────────────────
    if ($isCleanTag -and -not $AllTagsAsBranches) {
        # Phase 6: annotated tag via tagger env vars
        # Idempotency: skip if tag already exists (re-run safety)
        $existingTagCommit = Invoke-Git -GitDir $GitDir `
                                        -GitArgs @('rev-list', '-n', '1', "refs/tags/$($Ref.TagName)") `
                                        -AllowFailure
        if ($existingTagCommit) {
            if ($existingTagCommit -eq $lastCommitSha) {
                Write-Log "  Tag $($Ref.TagName) already exists at correct commit — skipping."
            } else {
                Write-Log ("  Tag $($Ref.TagName) already exists at a different commit " +
                    "($($existingTagCommit.Substring(0,8))). Skipping to preserve existing tag.") -Level WARN
            }
            # No-op re-run / finalize-only path — do NOT increment TotalTags.
            Write-Log "  → tag $($Ref.TagName) (existing)"
        } else {
            Set-GitAuthorEnv -Name $lastAuthorInfo.Name -Email $lastAuthorInfo.Email `
                             -Date $lastGitDate
            try {
                & git -C $GitDir tag -a -m "SVN tag $($Ref.TagName)" `
                      --cleanup=verbatim $Ref.TagName $lastCommitSha 2>&1 | Out-Null
                if ($LASTEXITCODE -ne 0) {
                    Write-Log "  git tag failed for $($Ref.TagName)" -Level WARN
                }
            }
            finally {
                Clear-GitAuthorEnv
            }
            $Script:Stats.TotalTags++
            Write-Log "  → tag $($Ref.TagName) @ $($lastCommitSha.Substring(0,8))"
        }
    }
    else {
        # Idempotency: branches had no re-run check at all — every re-run of an
        # already-converted ref blindly incremented TotalBranches. Skip the
        # increment (and the redundant update-ref) when the ref already points
        # at this exact commit (no-op re-run / finalize-only path).
        $existingBranchSha = Invoke-Git -GitDir $GitDir `
                                        -GitArgs @('rev-parse', '--verify', $effectiveRefName) `
                                        -AllowFailure
        if ($existingBranchSha -and $existingBranchSha -eq $lastCommitSha) {
            Write-Log "  → $effectiveRefName already @ $($lastCommitSha.Substring(0,8)) — skipping."
        }
        else {
            Invoke-Git -GitDir $GitDir `
                       -GitArgs @('update-ref', $effectiveRefName, $lastCommitSha) | Out-Null
            $Script:Stats.TotalBranches++
            Write-Log "  → $effectiveRefName @ $($lastCommitSha.Substring(0,8))"
        }
    }

    Invoke-GitGcAuto -GitDir $GitDir -Phase $Phase

    # Clean up the SVN working copy now that this ref is committed to git
    if (Test-Path $StagingDir) { Remove-Item $StagingDir -Recurse -Force -ErrorAction SilentlyContinue }

    return 'complete'
}

# ─────────────────────────────────────────────────────────────────────────────
# PHASE 7 — POST-PROCESSING
# ─────────────────────────────────────────────────────────────────────────────

function Invoke-CreateIgnore {
    <#
    For each ref, query svn:ignore under that ref's SVN URL at HEAD,
    write .gitignore files to the git working tree, and commit.
    #>
    param(
        [System.Collections.Generic.List[pscustomobject]]$Refs,
        [string]$GitDir,
        [string]$StagingDir,
        [string]$RepoUuid,
        [System.Collections.Generic.Dictionary[string,hashtable]]$AuthorMap,
        [string]$SourceEncoding
    )

    Write-Log '── Phase 7.1: Converting svn:ignore → .gitignore'

    foreach ($ref in $Refs) {
        # Skip clean annotated tags — .gitignore commits do not belong on immutable tag points.
        # A dirty tag is already stored as a branch (refs/heads/tags/...) and IS processed.
        if ($ref.IsTag) {
            $dirtyBranchRef = "refs/heads/tags/$($ref.TagName)"
            $dirtyBranchSha = Invoke-Git -GitDir $GitDir `
                                         -GitArgs @('rev-parse', '--verify', $dirtyBranchRef) `
                                         -AllowFailure
            if (-not $dirtyBranchSha) {
                Write-Log "  Skipping svn:ignore for clean tag $($ref.TagName) (annotated tags are immutable)"
                continue
            }
            # Dirty tag: fall through — use the branch ref as effectiveRef below
        }

        # Skip refs that produced no commits
        $refSha = Invoke-Git -GitDir $GitDir `
                             -GitArgs @('rev-parse', '--verify', $ref.RefName) `
                             -AllowFailure
        # Also check for effective branch name for dirty tags
        if (-not $refSha) {
            $altName = if ($ref.IsTag) { "refs/heads/tags/$($ref.TagName)" } else { $null }
            if ($altName) {
                $refSha = Invoke-Git -GitDir $GitDir `
                                     -GitArgs @('rev-parse', '--verify', $altName) `
                                     -AllowFailure
            }
        }
        if (-not $refSha) { continue }

        # Effective ref name (dirty tags become branches)
        $effectiveRef = $ref.RefName
        if ($ref.IsTag) {
            $altRef = "refs/heads/tags/$($ref.TagName)"
            $altSha = Invoke-Git -GitDir $GitDir `
                                 -GitArgs @('rev-parse', '--verify', $altRef) `
                                 -AllowFailure
            if ($altSha) { $effectiveRef = $altRef }
        }

        # Resolve the commit SHA (dereferences tag objects to their target commit)
        $parentCommitSha = Invoke-Git -GitDir $GitDir `
                                      -GitArgs @('rev-parse', "${effectiveRef}^{commit}") `
                                      -AllowFailure
        if (-not $parentCommitSha) {
            Write-Log "  Cannot resolve commit for $effectiveRef — skipping .gitignore pass." -Level WARN
            continue
        }

        Write-Log "  Processing svn:ignore for $effectiveRef ($($ref.SvnUrl))"

        # Checkout HEAD of this ref locally — replaces svn export (faster, no temp staging)
        try {
            Initialize-SvnWorkingCopy -Url $ref.SvnUrl -Rev 'HEAD' -WcDir $StagingDir
        }
        catch {
            Write-Log "  Could not checkout $($ref.SvnUrl) for .gitignore pass." -Level WARN
            continue
        }

        # Query svn:ignore from LOCAL working copy — zero network round-trips
        try {
            $ignoreXml = Invoke-SvnXml `
                -SvnArgs @('propget', 'svn:ignore', '--xml', '--depth', 'infinity',
                            $StagingDir) `
                -SourceEncoding $SourceEncoding
        }
        catch {
            Write-Log "  Could not query svn:ignore for $($ref.SvnUrl)" -Level WARN
            if (Test-Path $StagingDir) { Remove-Item $StagingDir -Recurse -Force -ErrorAction SilentlyContinue }
            continue
        }

        $gitIgnoreMap = @{}   # relPath → list of patterns
        foreach ($tgt in $ignoreXml.SelectNodes('//target')) {
            $tgtPath  = $tgt.GetAttribute('path')
            $propNode = $tgt.SelectSingleNode('property[@name="svn:ignore"]')
            if (-not $propNode) { continue }
            $patterns = $propNode.InnerText -split "`n" |
                        ForEach-Object { $_.Trim() } |
                        Where-Object   { $_ -ne '' }
            if ($patterns) {
                # path="." means the root; strip leading ./ or /
                $dirKey = $tgtPath.TrimStart('.').TrimStart('/').TrimStart('\')
                $gitIgnoreMap[$dirKey] = $patterns
            }
        }

        if ($gitIgnoreMap.Count -eq 0) {
            if (Test-Path $StagingDir) { Remove-Item $StagingDir -Recurse -Force -ErrorAction SilentlyContinue }
            continue
        }

        # Mirror WC → git working tree (robocopy handles adds/modifies/deletes)
        Copy-WcToRepo -WcDir $StagingDir -GitDir $GitDir -IgnorePattern '' -IncludePattern ''
        # Clean up WC — no longer needed after mirror
        if (Test-Path $StagingDir) { Remove-Item $StagingDir -Recurse -Force -ErrorAction SilentlyContinue }

        # Read the current ref's HEAD into the index
        Invoke-Git -GitDir $GitDir -GitArgs @('add', '-A') | Out-Null

        $anyChange = $false
        foreach ($dir in $gitIgnoreMap.Keys) {
            $destDir = if ($dir) { Join-Path $GitDir $dir } else { $GitDir }
            if (-not (Test-Path $destDir)) {
                New-Item -ItemType Directory -Path $destDir -Force | Out-Null
            }
            $gitIgnorePath = Join-Path $destDir '.gitignore'

            # Merge with existing .gitignore (append + deduplicate)
            $existing = @()
            if (Test-Path $gitIgnorePath) {
                $existing = Get-Content $gitIgnorePath |
                            ForEach-Object { $_.Trim() } |
                            Where-Object   { $_ -ne '' }
            }
            $merged = ($existing + $gitIgnoreMap[$dir]) | Select-Object -Unique
            [System.IO.File]::WriteAllLines($gitIgnorePath, [string[]]$merged, (New-Object System.Text.UTF8Encoding($false)))
            $anyChange = $true
        }

        if (-not $anyChange) { continue }

        Invoke-Git -GitDir $GitDir -GitArgs @('add', '-A') | Out-Null

        $newTreeSha = Invoke-Git -GitDir $GitDir -GitArgs @('write-tree')
        $oldTreeSha = Invoke-Git -GitDir $GitDir `
                                 -GitArgs @('rev-parse', "${effectiveRef}^{tree}") `
                                 -AllowFailure
        if ($newTreeSha -eq $oldTreeSha) { continue }

        # Use a generic bot identity for the .gitignore commit
        Set-GitAuthorEnv `
            -Name  'SVN Migration' `
            -Email "migration@$RepoUuid" `
            -Date  (Get-Date -Format 'yyyy-MM-ddTHH:mm:ss +0000')
        try {
            $msg = 'Add .gitignore from svn:ignore'
            $oldEAP = $ErrorActionPreference
            $ErrorActionPreference = 'Continue'
            $newCommitSha = $msg |
                & git -C $GitDir commit-tree $newTreeSha -p $parentCommitSha 2>&1
            $ErrorActionPreference = $oldEAP
            if ($LASTEXITCODE -ne 0) {
                Write-Log "  git commit-tree failed for .gitignore on $effectiveRef" -Level WARN
                continue
            }
            $newCommitSha = ($newCommitSha -join '').Trim()
        }
        finally {
            Clear-GitAuthorEnv
        }

        Invoke-Git -GitDir $GitDir `
                   -GitArgs @('update-ref', $effectiveRef, $newCommitSha) | Out-Null
        Write-Log "  → ${effectiveRef}: added .gitignore commit $($newCommitSha.Substring(0,8))"
        $Script:Stats.TotalCommits++
    }
}

# ─────────────────────────────────────────────────────────────────────────────
# PHASE 8 — VERIFICATION SUMMARY
# ─────────────────────────────────────────────────────────────────────────────

function Write-Summary {
    param([string]$GitDir, [string]$SvnUrl)

    # Ref counts are derived LIVE from the git repo rather than trusted from
    # the persisted TotalBranches/TotalTags counters. Those counters only
    # ever go up — re-running an already-converted phase 4/5/6 (idempotent
    # by design) used to re-increment them on every no-op re-run, inflating
    # the summary (e.g. "3 branches, 2 tags" for a repo with 2 branches, 1
    # tag). git itself is always the ground truth for what refs exist.
    $branchCount = 0
    $tagCount    = 0
    try {
        $branchLines = & git -C $GitDir for-each-ref --format='%(refname)' refs/heads 2>&1
        if ($LASTEXITCODE -eq 0) { $branchCount = @($branchLines | Where-Object { $_ }).Count }

        $tagLines = & git -C $GitDir for-each-ref --format='%(refname)' refs/tags 2>&1
        if ($LASTEXITCODE -eq 0) { $tagCount = @($tagLines | Where-Object { $_ }).Count }
    }
    catch {
        Write-Log "  Could not enumerate refs for summary: $_" -Level WARN
    }

    $totalRefs = $branchCount + $tagCount
    $dirtyList = if ($Script:Stats.DirtyTags.Count -gt 0) {
        $Script:Stats.DirtyTags -join ', '
    } else { '(none)' }
    $unmapList = if ($Script:Stats.UnmappedAuthors.Count -gt 0) {
        $Script:Stats.UnmappedAuthors -join ', '
    } else { '(none)' }
    $orphList  = if ($Script:Stats.OrphanedBranches.Count -gt 0) {
        $Script:Stats.OrphanedBranches -join ', '
    } else { '(none)' }

    Write-Host ''
    Write-Host '═══════════════════════════════════════════════════════' -ForegroundColor Green
    Write-Host ' Migration complete.' -ForegroundColor Green
    Write-Host "   Refs:                       $branchCount branches, $tagCount tags"
    Write-Host "   Commits:                    $($Script:Stats.TotalCommits)"
    Write-Host "   SVN revisions processed:    $($Script:Stats.SvnRevisions)"
    Write-Host "   Skipped (empty after filter): $($Script:Stats.SkippedEmpty)"
    Write-Host "   Dirty tags → branches:      $dirtyList"
    Write-Host "   Unmapped SVN authors:        $unmapList"
    Write-Host "   Orphaned branches:           $orphList"
    Write-Host ''
    Write-Host ' Next steps:'
    Write-Host "   git remote add origin <remote-url>"
    Write-Host "   git push --all origin"
    Write-Host "   git push --tags origin"
    Write-Host ''
    Write-Host ' To strip git-svn-id trailers from all commits (irreversible):'
    Write-Host "   git filter-repo --message-callback 'return re.sub(rb""\ngit-svn-id:.*"", b"""", message)'"
    Write-Host '═══════════════════════════════════════════════════════' -ForegroundColor Green
}

# ─────────────────────────────────────────────────────────────────────────────
# PREREQUISITE CHECK
# ─────────────────────────────────────────────────────────────────────────────

function Assert-Prerequisites {
    $missing = @()
    if (-not (Get-Command svn -ErrorAction SilentlyContinue)) { $missing += 'svn' }
    if (-not (Get-Command git -ErrorAction SilentlyContinue)) { $missing += 'git' }
    if ($missing) {
        Write-Log "Missing required tools: $($missing -join ', ')" -Level ERROR
        Write-Log 'Install svn (SlikSVN/TortoiseSVN) and git 2.x, ensure both are on PATH.' -Level ERROR
        exit 1
    }

    # git version check ≥ 2.x
    $gv = (& git --version 2>&1) -replace '[^\d\.]',''
    $major = [int](($gv -split '\.')[0])
    if ($major -lt 2) {
        Write-Log "git 2.x required (found: $gv)" -Level ERROR
        exit 1
    }
}
# ─────────────────────────────────────────────────────────────────────────────
# PHASE CONTEXT HELPERS  (called by run-phase.pslib after core is loaded)
# ─────────────────────────────────────────────────────────────────────────────

function Initialize-PhaseContext {
    <#
    Standard phase bootstrap called once after dot-sourcing core.pslib.
    Initialises ShaIndex + Stats, imports persisted state, reads config.json,
    and returns the config object.
    #>
    param([string]$StateDir)

    $Script:ShaIndex = [System.Collections.Generic.Dictionary[string,
        [System.Collections.Generic.SortedDictionary[int,string]]]]::new()
    $Script:Stats = New-StatsObject
    Import-MigrationState -StateDir $StateDir

    return (Get-Content "$StateDir\config.json" -Raw | ConvertFrom-Json)
}

function Import-RefList {
    <#
    Read refs.json from $StateDir and return a typed Generic.List of pscustomobject.
    Eliminates the 12-line boilerplate repeated in phases 4-7.
    #>
    param([string]$StateDir)

    $refsJson = Get-Content "$StateDir\refs.json" -Raw | ConvertFrom-Json
    $refs = [System.Collections.Generic.List[pscustomobject]]::new()
    foreach ($r in $refsJson) {
        $refs.Add([pscustomobject]@{
            RefName     = $r.RefName
            SvnUrl      = $r.SvnUrl
            IsTag       = [bool]$r.IsTag
            TagName     = $r.TagName
            CopyfromUrl = $r.CopyfromUrl
            CopyfromRev = $r.CopyfromRev
        })
    }
    return $refs
}

function New-StagingDir {
    <#
    Create a unique temp directory for the SVN working copy and return the
    path to the 'staging' subdirectory that Invoke-ConvertRef will use.
    The parent ($tempBase) is what the caller's finally-block should remove.
    Returns [pscustomobject]@{ StagingDir; TempBase }
    #>
    $tempBase   = Join-Path ([System.IO.Path]::GetTempPath()) "svn2git_$(Get-Random)"
    $stagingDir = Join-Path $tempBase 'staging'
    New-Item -ItemType Directory -Path $tempBase -Force | Out-Null
    return [pscustomobject]@{ StagingDir = $stagingDir; TempBase = $tempBase }
}

# ─────────────────────────────────────────────────────────────────────────────
# STATE PERSISTENCE
# ─────────────────────────────────────────────────────────────────────────────

function Save-ShaIndex {
    param($ShaIndex, [string]$Path)
    $o = [ordered]@{}
    foreach ($url in $ShaIndex.Keys) {
        $inner = [ordered]@{}
        foreach ($rev in $ShaIndex[$url].Keys) { $inner["$rev"] = $ShaIndex[$url][$rev] }
        $o[$url] = $inner
    }
    $o | ConvertTo-Json -Depth 6 | Set-Content -LiteralPath $Path -Encoding UTF8
}

function Import-ShaIndex {
    param([string]$Path)
    $idx = [System.Collections.Generic.Dictionary[string,
            System.Collections.Generic.SortedDictionary[int,string]]]::new()
    if (-not (Test-Path $Path)) { return $idx }
    $json = Get-Content -LiteralPath $Path -Raw | ConvertFrom-Json
    foreach ($p in $json.PSObject.Properties) {
        $sd = [System.Collections.Generic.SortedDictionary[int,string]]::new()
        foreach ($rp in $p.Value.PSObject.Properties) { $sd[[int]$rp.Name] = $rp.Value }
        $idx[$p.Name] = $sd
    }
    return $idx
}

function New-StatsObject {
    [pscustomobject]@{
        TotalBranches    = 0
        TotalTags        = 0
        TotalCommits     = 0
        SvnRevisions     = 0
        SkippedEmpty     = 0
        DirtyTags        = [System.Collections.Generic.List[string]]::new()
        UnmappedAuthors  = [System.Collections.Generic.HashSet[string]]::new()
        OrphanedBranches = [System.Collections.Generic.List[string]]::new()
    }
}

function Save-MigrationState {
    param([string]$StateDir)
    $null = New-Item -ItemType Directory -Path $StateDir -Force
    Save-ShaIndex -ShaIndex $Script:ShaIndex -Path (Join-Path $StateDir 'sha-index.json')
    $statsJson = [ordered]@{
        TotalBranches    = $Script:Stats.TotalBranches
        TotalTags        = $Script:Stats.TotalTags
        TotalCommits     = $Script:Stats.TotalCommits
        SvnRevisions     = $Script:Stats.SvnRevisions
        SkippedEmpty     = $Script:Stats.SkippedEmpty
        DirtyTags        = @($Script:Stats.DirtyTags)
        UnmappedAuthors  = @($Script:Stats.UnmappedAuthors)
        OrphanedBranches = @($Script:Stats.OrphanedBranches)
    }
    $statsJson | ConvertTo-Json -Depth 4 | Set-Content (Join-Path $StateDir 'stats.json') -Encoding UTF8
}

function Write-MigrationProgress {
    <#
    Write $StateDir\progress.json (single ConvertTo-Json, overwrite) so an
    external poller can show live status for the ref currently being
    converted. Called once per processed revision from Invoke-ConvertRef.
    Degrades gracefully to a no-op when $StateDir is empty/absent so callers
    that don't pass phase/state-dir context (e.g. ad-hoc testing) still work.
    #>
    param(
        [string]$StateDir,
        [string]$Phase,
        [string]$RefName,
        [int]   $Rev,
        [int]   $RevIndex,
        [int]   $RevTotal,
        [int]   $Commits,
        [ValidateSet('running', 'checkpoint', 'complete', 'error')]
        [string]$Status,
        [string]$Message = ''
    )
    if (-not $StateDir) { return }

    $obj = [ordered]@{
        phase     = $Phase
        ref       = $RefName
        rev       = $Rev
        revIndex  = $RevIndex
        revTotal  = $RevTotal
        commits   = $Commits
        status    = $Status
        message   = $Message
        updatedAt = (Get-Date).ToUniversalTime().ToString('yyyy-MM-ddTHH:mm:ssZ')
    }
    try {
        $obj | ConvertTo-Json -Depth 4 |
            Set-Content -LiteralPath (Join-Path $StateDir 'progress.json') -Encoding UTF8
    }
    catch {
        Write-Log "  Could not write progress.json: $_" -Level WARN
    }
}

function Import-MigrationState {
    param([string]$StateDir)
    $shaPath = Join-Path $StateDir 'sha-index.json'
    $Script:ShaIndex = Import-ShaIndex -Path $shaPath
    $statsPath = Join-Path $StateDir 'stats.json'
    if (Test-Path $statsPath) {
        $j = Get-Content $statsPath -Raw | ConvertFrom-Json
        $Script:Stats = New-StatsObject
        $Script:Stats.TotalBranches = $j.TotalBranches
        $Script:Stats.TotalTags     = $j.TotalTags
        $Script:Stats.TotalCommits  = $j.TotalCommits
        $Script:Stats.SvnRevisions  = $j.SvnRevisions
        $Script:Stats.SkippedEmpty  = $j.SkippedEmpty
        foreach ($t in $j.DirtyTags)        { $null = $Script:Stats.DirtyTags.Add($t) }
        foreach ($a in $j.UnmappedAuthors)  { $null = $Script:Stats.UnmappedAuthors.Add($a) }
        foreach ($b in $j.OrphanedBranches) { $null = $Script:Stats.OrphanedBranches.Add($b) }
    }
}